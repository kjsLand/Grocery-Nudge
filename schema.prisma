generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  phone        String   @unique
  createdAt    DateTime @default(now())
}

model Group {
  id          String   @id @default(uuid())
  title       String
  leaderId    String
  description String
  image       String?  // S3 object key or full URL, nullable until uploaded
  type        String   // "SPLITTER" | "GROCERY_LIST" — consider an enum instead

  @@unique([leaderId, title], name: "leaderId_title")
}

model UserGroups {
  id          String    @id @default(uuid())
  userId      String
  groupId     String
}

model Invite{
  id          String    @id @default(uuid())
  groupId     String
  senderId    String
  receiverId  String
  status      String
  createdAt   DateTime @default(now())
}

model GroceryList {
  id          String    @id @default(uuid())
  groupId     String
}

model GroceryItem {
  id          String    @id @default(uuid())
  listId      String
  name        String
  quantity    Int
  price       String
  isCompleted Boolean
  addedById   String
  assignedId  String
}